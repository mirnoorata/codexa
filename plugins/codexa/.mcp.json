{
  "mcpServers": {
    "codexa": {
      "command": "node",
      "args": [
        "./scripts/codexa-mcp.js"
      ],
      "env_vars": [
        "CODEXA_REPO",
        "CODEXA_FOCUSED_REPO",
        "CODEXA_WORKSPACE_FOCUS_FILE",
        "CODEX_WORKSPACE",
        "CODEX_WORKSPACE_ROOT",
        "CODEXA_PLUGIN_AUTO_REFRESH"
      ],
      "startup_timeout_sec": 10,
      "tool_timeout_sec": 60
    }
  }
}
